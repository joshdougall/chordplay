# Generate with: openssl rand -base64 32
APP_SECRET=

# From your streaming service developer dashboard (e.g. Spotify Developer Dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Directories for chord/tab files and app data (tokens, prefs, cache)
# Defaults shown — override if needed
LIBRARY_PATH=./data/library
DATA_PATH=./data/app

# Optional
LOG_LEVEL=info
